[Unit]
Description=Mimick — Background Photo Sync for Immich
Documentation=https://github.com/nicx17/mimick
After=network.target network-online.target graphical-session.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/mimick
Restart=on-failure
RestartSec=5s
# Forward logs to the journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
