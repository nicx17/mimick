# Maintainer: Nick <nick@nickcardoso.com>
pkgname=mimick
pkgver=2.0.1
pkgrel=1
pkgdesc="A background daemon to auto-sync photos to Immich on Linux"
arch=('x86_64')
url="https://github.com/nicx17/mimick"
license=('GPL3')
depends=('gtk4' 'libadwaita' 'libsecret' 'ksni')
makedepends=('rust' 'cargo' 'pkg-config')
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    cargo build --release --locked
}

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # Install binary
    install -Dm755 "target/release/mimick" "$pkgdir/usr/bin/mimick"

    # Install .desktop file
    install -Dm644 setup/mimick.desktop "$pkgdir/usr/share/applications/mimick.desktop"

    # Install icons
    install -Dm644 src/assets/icon.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/mimick.svg"
    install -Dm644 src/assets/icon.png "$pkgdir/usr/share/icons/hicolor/128x128/apps/mimick.png"

    # Install metainfo
    install -Dm644 setup/metainfo/io.github.nicx17.mimick.metainfo.xml \
        "$pkgdir/usr/share/metainfo/io.github.nicx17.mimick.metainfo.xml"

    # Install systemd user service
    install -Dm644 setup/mimick.service "$pkgdir/usr/lib/systemd/user/mimick.service"
}
